VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Resend — server-side only (never prefix with VITE_)
# Replace re_xxxxxxxxx with your real API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM=Swift Challenge Fest <onboarding@resend.dev>

# Optional: link in confirmation email CTA button
SITE_URL=http://localhost:5173

# Optional: recipient for `pnpm email:test`
RESEND_TEST_TO=you@example.com
